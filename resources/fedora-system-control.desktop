[Desktop Entry]
Type=Application
Name=Fedora System Control
Comment=System monitoring and control dashboard for Fedora Linux
Exec=/usr/bin/fedora-system-control
Icon=fedora-system-control
Categories=System;Monitor;Utility;
Terminal=false
StartupNotify=false
X-GNOME-Autostart-enabled=true
X-GNOME-Autostart-Delay=5
X-KDE-autostart-phase=1
